rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check user role
    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    // Helper function to validate timestamps
    function isValidTimestamp(ts) {
      return ts is timestamp && ts <= now;
    }

    // Users collection
    match /users/{uid} {
      allow read: if request.auth.uid == uid;
      allow read: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
      allow create: if request.auth.uid == uid &&
                     request.resource.data.role in ['normal_user', 'club_head', 'admin'] &&
                     request.resource.data.email == request.auth.token.email &&
                     isValidTimestamp(request.resource.data.createdAt);
      allow update: if request.auth.uid == uid &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.createdAt == resource.data.createdAt &&
                     request.resource.data.email == resource.data.email &&
                     isValidTimestamp(request.resource.data.updatedAt);
      allow update: if getUserRole(request.auth.uid) == 'admin';
      allow delete: if getUserRole(request.auth.uid) == 'admin';
    }

    // Admin email whitelist
    match /adminEmails/{document=**} {
      allow read, write: if false;
    }

    // Clubs collection
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                     getUserRole(request.auth.uid) in ['club_head', 'admin'] &&
                     isValidTimestamp(request.resource.data.createdAt) &&
                     request.resource.data.members is list &&
                     request.resource.data.name != null;
      allow update: if request.auth != null && (
                     getUserRole(request.auth.uid) == 'admin' ||
                     (resource.data.president == request.auth.uid &&
                      getUserRole(request.auth.uid) == 'club_head')
                    ) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    isValidTimestamp(request.resource.data.updatedAt);
      allow delete: if request.auth != null &&
                     getUserRole(request.auth.uid) == 'admin';
    }

    // Events collection
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                     getUserRole(request.auth.uid) in ['club_head', 'admin'] &&
                     isValidTimestamp(request.resource.data.createdAt) &&
                     request.resource.data.title != null &&
                     request.resource.data.date != null;
      allow update: if request.auth != null && (
                     getUserRole(request.auth.uid) == 'admin' ||
                     (resource.data.createdBy == request.auth.uid &&
                      getUserRole(request.auth.uid) == 'club_head')
                    ) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    isValidTimestamp(request.resource.data.updatedAt);
      allow delete: if request.auth != null &&
                     getUserRole(request.auth.uid) == 'admin';
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
